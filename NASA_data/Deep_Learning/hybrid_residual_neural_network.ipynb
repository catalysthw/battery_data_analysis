# 1. 피처 추출 및 정규화
def prepare_ultimate_dataset(metadata, data_folder, target_steps=150):
    all_X_seq, all_X_stats, all_y, all_ids, all_max_cycles = [], [], [], [], []
    discharge_meta = metadata[metadata['type'] == 'discharge'].copy()
    unique_battery_ids = discharge_meta['battery_id'].unique()

    for b_id in unique_battery_ids:
        b_df = discharge_meta[discharge_meta['battery_id'] == b_id].sort_values('filename')
        max_cycle_count = len(b_df)
        
        for i, row in enumerate(b_df.itertuples(), 1):
            file_path = os.path.join(data_folder, "data", row.filename)
            if not os.path.exists(file_path): continue
                
            try:
                df = pd.read_csv(file_path)
                if len(df) < 110: continue

                # [A] CNN용 Raw 시퀀스 (보간법)
                cols = ['Time', 'Voltage_measured', 'Voltage_load', 'Current_measured', 'Temperature_measured']
                raw_values = df[cols].values
                interp_func = interp1d(np.linspace(0, 1, len(df)), raw_values, axis=0, kind='linear')
                resampled_seq = interp_func(np.linspace(0, 1, target_steps))

                # [B] DNN용 물리 특징
                v_init = df['Voltage_measured'].iloc[0]
                try:
                    v_drop_idx = df[df['Current_measured'].abs() > 0.1].index[0]
                    v_jump = v_init - df['Voltage_measured'].iloc[v_drop_idx]
                except: v_jump = 0
                
                dt = df['Time'].diff().fillna(0)
                total_cap = (df['Current_measured'].abs() * dt).sum() / 3600
                temp_delta = df['Temperature_measured'].max() - df['Temperature_measured'].min()

                # DNN 입력: [현재 사이클 비율, v_jump, total_cap, temp_delta]
                # i/max_cycle_count를 넣어 모델에게 '진행률' 맥락을 줍니다.
                stat_vector = [i / max_cycle_count, v_jump, total_cap, temp_delta]

                all_X_seq.append(resampled_seq)
                all_X_stats.append(stat_vector)
                
                # 정규화: 남은 사이클
                all_y.append((max_cycle_count - i) / max_cycle_count)
                all_ids.append(b_id)
                all_max_cycles.append(max_cycle_count) # 나중에 결과 복원용
                
            except: continue
                
    return np.array(all_X_seq), np.array(all_X_stats), np.array(all_y), np.array(all_ids), np.array(all_max_cycles)
    return np.array(all_X_seq), np.array(all_X_stats), pd.DataFrame(all_targets), np.array(all_ids)



def prepare_advanced_hrnn_dataset(metadata, data_folder, target_steps=150, num_samples_per_file=10):
    all_X_seq, all_X_stats, all_targets, all_ids = [], [], [], []
    
    discharge_meta = metadata[metadata['type'] == 'discharge'].copy()

    # Capacity 타입 강제 변환 (to nummeric)
    discharge_meta['Capacity'] = pd.to_numeric(discharge_meta['Capacity'], errors='coerce')
    unique_battery_ids = discharge_meta['battery_id'].unique()

    for b_id in unique_battery_ids:
        b_df = discharge_meta[discharge_meta['battery_id'] == b_id].sort_values('filename')
        total_cycles = len(b_df)
        b_cap_max = b_df['Capacity'].max()
        
        for i, row_meta in enumerate(b_df.itertuples(), 1):
            file_path = os.path.join(data_folder, "data", row_meta.filename)
            if not os.path.exists(file_path): continue
            
            try:
                df = pd.read_csv(file_path)
                if len(df) < 110: continue
                
                # [1] CNN/ResNet용 시퀀스 생성 (보간)
                cols = ['Voltage_measured', 'Current_measured', 'Temperature_measured']
                raw_values = df[cols].values
                interp_func = interp1d(np.linspace(0, 1, len(df)), raw_values, axis=0, kind='linear')
                resampled_seq = interp_func(np.linspace(0, 1, target_steps))

                # [2] 물리/통계 피처 추출
                v_vals = df['Voltage_measured'].values
                t_vals = df['Time'].values
                dt = df['Time'].diff().fillna(0)
                cum_discharged_ah = (df['Current_measured'].abs() * dt).cumsum() / 3600
                calc_total_cap = cum_discharged_ah.iloc[-1]
                
                # V-jump
                v_init = v_vals[0]
                try:
                    v_drop_idx = df[df['Current_measured'].abs() > 0.1].index[0]
                    v_jump = v_init - v_vals[v_drop_idx]
                except: v_jump = 0
                
                # [3] 샘플링 루프 (한 파일 내 여러 지점 학습)
                # regressor 때처럼 한 파일당 여러 샘플을 뽑아 학습 데이터 샘플 확보
                indices = np.linspace(100, len(df)-11, num_samples_per_file, dtype=int)
                
                for idx in indices:
                    # 통계 피처
                    past_df = df.iloc[:idx]
                    aggs = past_df[cols].agg(['mean', 'std'])
                    
                    current_discharged = cum_discharged_ah.iloc[idx]
                    meta_cap_idx = row_meta.Capacity
                    
                    # 피처 생성 (DNN 입력용)
                    stat_vector = [
                        i,                          # cycle_count
                        v_vals[idx],                # 현재 전압
                        df['Current_measured'].iloc[idx], 
                        df['Temperature_measured'].iloc[idx],
                        v_jump,
                        (v_vals[idx] - v_vals[idx-20]) / (t_vals[idx] - t_vals[idx-20] + 1e-9), # slope_20
                        current_discharged / b_cap_max,       # rel_dis_ratio_meta
                        abs(meta_cap_idx - calc_total_cap),   # cap_error_abs
                        aggs.loc['mean', 'Voltage_measured'], 
                        aggs.loc['std', 'Voltage_measured'],
                        aggs.loc['mean', 'Temperature_measured']
                    ]

                    # 멀티 타겟 리스트 설정 (딕셔너리 형태로 저장하여 선택 가능)
                    target_dict = {
                        'SOH': meta_cap_idx / b_cap_max,
                        'RUL_time': t_vals[-1] - t_vals[idx],
                        'Rem_Cycles': total_cycles - i,
                        'Life_Ratio': (total_cycles - i) / total_cycles,
                        'MRAC': max(0, meta_cap_idx - current_discharged) / (meta_cap_idx + 1e-9)
                    }

                    all_X_seq.append(resampled_seq)
                    all_X_stats.append(stat_vector)
                    all_targets.append(target_dict)
                    all_ids.append(b_id)
                    
            except Exception as e: 
                continue
                
    return np.array(all_X_seq), np.array(all_X_stats), pd.DataFrame(all_targets), np.array(all_ids)



# 2. Residual Block 정의
def residual_block(x, filters, kernel_size=3):
    shortcut = x
    x = Conv1D(filters, kernel_size, padding='same')(x)
    x = BatchNormalization()(x)
    x = Activation('swish')(x)
    x = Conv1D(filters, kernel_size, padding='same')(x)
    x = BatchNormalization()(x)
    x = Add()([x, shortcut])
    x = Activation('swish')(x)
    return x


# 3. 하이브리드 모델 빌드
def build_ultimate_model(seq_shape, stats_shape):
    seq_in = Input(shape=seq_shape)
    # 필터 수를 64에서 32로 줄여 연산량 감소, 대신 커널 사이즈로 특징 포착
    x = Conv1D(32, 7, padding='same')(seq_in)
    x = BatchNormalization()(x)
    x = Activation('swish')(x)
    
    # Residual Block을 1개로 축소하되 성능 유지
    shortcut = x
    x = Conv1D(32, 3, padding='same')(x)
    x = BatchNormalization()(x)
    x = Activation('swish')(x)
    x = Add()([x, shortcut])
    
    x = GlobalAveragePooling1D()(x)

    # DNN Branch
    stats_in = Input(shape=stats_shape)
    y = Dense(16, activation='swish')(stats_in)
    
    merged = concatenate([x, y])
    z = Dense(32, activation='swish')(merged)
    out = Dense(1)(z)

    model = Model(inputs=[seq_in, stats_in], outputs=out)
    # Learning Rate를 조금 높여서 더 빨리 수렴하게 유도 (0.001)
    model.compile(optimizer=tf.keras.optimizers.Adam(0.001), loss='huber')
    return model



# --- 메인 실행부 ---
# 경로 및 파라미터
DATA_FOLDER = "/kaggle/input/nasa-battery-dataset/cleaned_dataset"        # 실제 데이터 폴더 경로로 수정
META_PATH = os.path.join(data_folder, "metadata.csv")


X_s, X_st, y_all, id_all, max_c_all = prepare_ultimate_dataset(meta_data, DATA_FOLDER)

# 정규화
X_s_scaled = StandardScaler().fit_transform(X_s.reshape(-1, 5)).reshape(X_s.shape)
X_st_scaled = StandardScaler().fit_transform(X_st)

unique_ids = np.unique(id_all)
results = []

# Test iteration
test_n = 10

for r in range(1, test_n + 1):
    train_ids, test_ids = train_test_split(unique_ids, test_size=0.2, random_state=random.randint(0,999))
    mask = np.isin(id_all, train_ids)
    t_mask = np.isin(id_all, test_ids)
    
    model = build_ultimate_model((150, 5), (4,))
    callback = tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=12, restore_best_weights=True)
    
    model.fit([X_s_scaled[mask], X_st_scaled[mask]], y_all[mask], 
              validation_split=0.2, 
              # validation_split=0.1,
              validation_freq=5,
              epochs=100, 
              # batch_size=32, 
              batch_size=128, 
              # batch_size=64 or 128, 
              verbose=0, 
              # verbose=1, 
              callbacks=[callback]
             )
    
    # 예측 및 복원 (비율 -> 사이클 수)
    y_pred_ratio = model.predict([X_s_scaled[t_mask], X_st_scaled[t_mask]]).flatten()
    y_pred_cycles = y_pred_ratio * max_c_all[t_mask]
    y_true_cycles = y_all[t_mask] * max_c_all[t_mask]
    
    r2 = r2_score(y_true_cycles, y_pred_cycles)
    mae = mean_absolute_error(y_true_cycles, y_pred_cycles)
    results.append({'R2': r2, 'MAE': mae})
    print(f"Run {r:02d} | R2: {r2:.4f} | MAE: {mae:.2f} cycles")

print("\n" + "="*50)
print(pd.DataFrame(results).mean())
print("="*50)





