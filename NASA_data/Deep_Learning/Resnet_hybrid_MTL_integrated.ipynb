# [Step 1] 순수 방전 구간 추출 및 보간 함수
def load_pure_discharge_v(file_path, target_steps=150):
    try:
        df = pd.read_csv(file_path)
        # 1. 전류가 흐르는 구간만 필터링 (방전 중)
        discharge_df = df[df['Current_measured'].abs() > 0.1].copy()
        if len(discharge_df) < 50: return None
        
        # 2. 전압 회복 구간 제거 (전압 최저점까지만 슬라이싱)
        # 방전이 끝나면 전압이 다시 올라가므로, 최저점이 실제 방전 종료 지점임
        min_v_idx = discharge_df['Voltage_measured'].idxmin()
        final_df = discharge_df.loc[:min_v_idx]
        
        v = final_df['Voltage_measured'].values
        t = final_df['Time'].values
        
        # 3. 시간 기반 정규화 및 보간
        t_norm = (t - t[0]) / (t[-1] - t[0])
        f_interp = interp1d(t_norm, v, kind='linear', fill_value="extrapolate")
        
        return f_interp(np.linspace(0, 1, target_steps)).reshape(-1, 1)
    except:
        return None

# [Step 2] 데이터 세트 준비
def prepare_generation_dataset_v3(metadata, data_folder, target_steps=150, pairs_per_battery=120):
    X_past, X_gap, y_future, ids = [], [], [], []
    discharge_meta = metadata[metadata['type'] == 'discharge'].copy()
    
    for b_id in discharge_meta['battery_id'].unique():
        b_df = discharge_meta[discharge_meta['battery_id'] == b_id].sort_values('filename')
        files = b_df['filename'].tolist()
        n_files = len(files)
        
        if n_files < 2: continue
        
        for _ in range(pairs_per_battery):
            i, j = sorted(random.sample(range(n_files), 2))
            v_i = load_pure_discharge_v(os.path.join(data_folder, "data", files[i]), target_steps)
            v_j = load_pure_discharge_v(os.path.join(data_folder, "data", files[j]), target_steps)
            
            if v_i is not None and v_j is not None:
                X_past.append(v_i)
                X_gap.append([(j - i) / n_files])
                y_future.append(v_j)
                ids.append(b_id)
                
    return np.array(X_past), np.array(X_gap), np.array(y_future), np.array(ids)



# [Step 3 수정] ResNet 기반 FiLM-Hybrid Generator 빌드
def build_resnet_curve_generator(seq_shape=(150, 1), gap_shape=(1,)):
    # 1. Inputs
    past_in = Input(shape=seq_shape, name='past_curve')
    gap_in = Input(shape=gap_shape, name='future_gap')

    # 2. ResNet Block (Shortcut Connection 추가)
    # 초기 특징 추출
    x = layers.Conv1D(64, kernel_size=7, padding='same')(past_in)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    
    # Residual Block 1
    shortcut = x
    x = layers.Conv1D(64, kernel_size=3, padding='same')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Activation('relu')(x)
    x = layers.Conv1D(64, kernel_size=3, padding='same')(x)
    x = layers.BatchNormalization()(x)
    x = layers.Add()([x, shortcut]) # 핵심: ResNet 잔차 연결
    x = layers.Activation('relu')(x)

    # 3. FiLM (Feature-wise Linear Modulation) - Gap 정보를 특징에 직접 주입
    # Gap 정보를 이용해 특징의 Scale과 Bias를 조절하여 오프셋 문제를 해결
    gamma = layers.Dense(64, activation='linear')(gap_in)
    beta = layers.Dense(64, activation='linear')(gap_in)
    gamma = layers.Reshape((1, 64))(gamma)
    beta = layers.Reshape((1, 64))(beta)
    x = layers.Multiply()([x, gamma]) 
    x = layers.Add()([x, beta])

    # 4. Global Context Extraction
    avg_pool = layers.GlobalAveragePooling1D()(x)
    gap_feat = layers.Dense(32, activation='relu')(gap_in)
    context = layers.concatenate([avg_pool, gap_feat])

    # 5. Decoder (LSTM)
    decoder_in = layers.RepeatVector(150)(context)
    y = layers.LSTM(128, return_sequences=True)(decoder_in)
    
    # Multi-Task Outputs
    # Task 1: 전체 곡선 예측 (Main)
    curve_out = layers.TimeDistributed(layers.Dense(1, activation='linear'), name='curve_output')(y)
    
    # Task 2: 초기 전압(오프셋) 예측 (Auxiliary)
    # 모델이 시작점을 더 정확히 맞추도록 강제하는 장치입니다.
    start_v_out = layers.Dense(1, name='start_v_output')(context)

    model = Model(inputs=[past_in, gap_in], outputs=[curve_out, start_v_out])
    
    # 기본 MSE, 두 태스크의 가중치를 조절
    model.compile(
        optimizer=tf.keras.optimizers.Adam(1e-4),
        loss={'curve_output': 'mse', 'start_v_output': 'mse'},
        loss_weights={'curve_output': 1.0, 'start_v_output': 0.5} # 시작점 보정 비중
    )
    return model


# [Step 4] 실행 및 시각화: 배터리 ID 기반 분할
def prepare_battery_data(metadata, data_folder, target_steps=150, test_size=0.25, random_state=42):
    all_rows = []
    
    # 1. 배터리 ID를 먼저 분할
    all_ids = metadata['battery_id'].unique()
    train_ids, test_ids = train_test_split(all_ids, test_size=test_size, random_state=random_state)
    print(f"학습용 배터리: {train_ids}")
    print(f"테스트용 배터리: {test_ids}")
    
    # 2. 데이터 수집 - for loop
    discharge_meta = metadata[metadata['type'] == 'discharge'].copy()
    
    for b_id in all_ids:
        b_df = discharge_meta[discharge_meta['battery_id'] == b_id].sort_values('filename')
        
        for i, row in enumerate(b_df.itertuples(), 1):
            file_path = os.path.join(data_folder, "data", row.filename)
            
            # [핵심] 정제된 전압 데이터 로드 (이전에 만든 회복구간 제거 함수 사용)
            v_curve = load_pure_discharge_v(file_path, target_steps)
            
            if v_curve is not None:
                # v_curve는 (150, 1) 형태의 Numpy array
                # 이를 딕셔너리에 담아 나중에 DataFrame으로 만듭니다.
                all_rows.append({
                    'battery_id': b_id,
                    'voltage_curve': v_curve.flatten(), # 행렬을 평탄화해서 저장
                    'cycle_count': i,
                    'total_cycles': len(b_df),
                    'target_rul_ratio': (len(b_df) - i) / len(b_df)
                })

    # 3. DataFrame 생성
    df_final = pd.DataFrame(all_rows)
    
    # 4. 전압 데이터 정규화 (X_p_norm 생성 과정)
    # 리스트 내의 배열들을 하나의 거대한 넘파이 행렬로 변환
    X_raw = np.stack(df_final['voltage_curve'].values)
    
    v_min, v_max = 2.0, 4.5
    X_norm = (X_raw - v_min) / (v_max - v_min)
    
    # 정규화된 데이터를 다시 DataFrame에 넣거나 따로 관리
    # train/test 분할
    train_mask = df_final['battery_id'].isin(train_ids)
    test_mask = df_final['battery_id'].isin(test_ids)
    
    # 최종 결과물 생성
    train_data = {
        'X_p_norm': X_norm[train_mask].reshape(-1, target_steps, 1),
        'y': df_final.loc[train_mask, 'target_rul_ratio'].values,
        'ids': df_final.loc[train_mask, 'battery_id'].values
    }
    
    test_data = {
        'X_p_norm': X_norm[test_mask].reshape(-1, target_steps, 1),
        'y': df_final.loc[test_mask, 'target_rul_ratio'].values,
        'ids': df_final.loc[test_mask, 'battery_id'].values
    }
    
    return train_data, test_data, train_ids, test_ids


# 데이터 로드
# 주의: 변수명 data_folder를 DATA_FOLDER 등 실제 경로 변수명과 맞춰주세요.
train_set_raw, test_set_raw, tr_ids, te_ids = prepare_battery_data(meta_data, data_folder, target_steps=150, test_size=0.2, random_state=42)

# Curve Generation을 위한 Pair 데이터셋 생성 함수
def create_pair_dataset(data_dict, ids_list, pairs_per_battery=120):
    X_p, X_g, y_f = [], [], []
    
    for b_id in ids_list:
        # 해당 배터리의 데이터만 추출
        mask = data_dict['ids'] == b_id
        b_curves = data_dict['X_p_norm'][mask] # (N, 150, 1)
        n_files = len(b_curves)
        
        if n_files < 2: continue
        
        for _ in range(pairs_per_battery):
            # 랜덤하게 과거(i)와 미래(j) 선택
            i, j = sorted(random.sample(range(n_files), 2))
            
            X_p.append(b_curves[i])
            X_g.append([(j - i) / n_files]) # 시간 간격(Gap) 정규화
            y_f.append(b_curves[j])
            
    return np.array(X_p), np.array(X_g), np.array(y_f)


# --- 학습 시 주의사항 ---
# 모델이 아웃풋을 두 개 내뱉으므로, y_f_tr도 두 개로 넣어줘야 합니다.
# generator = build_resnet_curve_generator((150, 1), (1,))
# y_start_tr = y_f_tr[:, 0, :]     # 미래 곡선의 첫 번째 전압값
# generator.fit([X_p_tr, X_g_tr], [y_f_tr, y_start_tr], epochs=60, batch_size=64)

# [Step 5] 데이터 가공 및 학습 시작
v_min, v_max = 2.0, 4.5

# 1. 페어링 데이터 생성 (이 부분이 실행되어야 y_f_tr이 메모리에 올라갑니다)
print(">>> 학습용/테스트용 페어링 데이터 생성 중...")
X_p_tr, X_g_tr, y_f_tr = create_pair_dataset(train_set_raw, tr_ids)
X_p_te, X_g_te, y_f_te = create_pair_dataset(test_set_raw, te_ids)

# 2. Multi-Task 학습을 위해 타겟 데이터를 두 개로 분리
# 메인 타겟: 전체 곡선 (150, 1)
y_f_tr_main = y_f_tr 
# 보조 타겟: 시작점 전압 (1,) -> 오프셋 방지용
y_f_tr_start = y_f_tr[:, 0, :] 

y_f_te_main = y_f_te
y_f_te_start = y_f_te[:, 0, :]

# 모델 빌드
generator = build_resnet_curve_generator((150, 1), (1,))

# 학습 실행 (두 개의 타겟을 리스트로 전달)
history = generator.fit(
    x=[X_p_tr, X_g_tr], 
    y={'curve_output': y_f_tr_main, 'start_v_output': y_f_tr_start},
    validation_split=0.1, 
    epochs=100,
    batch_size=64, 
    verbose=1
)


# [Step 6] 시각화 함수
def plot_resnet_hybrid_results(model, X_p, X_g, y_f, v_min, v_max, num_samples=10):
    indices = random.sample(range(len(X_p)), num_samples)
    plt.figure(figsize=(20, 10))
    
    def denorm(v): return v * (v_max - v_min) + v_min

    preds_all = model.predict([X_p, X_g])
    preds_curve = preds_all[0]
    preds_start = preds_all[1]

    for i, idx in enumerate(indices):
        plt.subplot(2, 5, i + 1)
        
        actual_past = denorm(X_p[idx])
        actual_future = denorm(y_f[idx])
        pred_curve = denorm(preds_curve[idx])
        
        # [핵심 수정] .item() 또는 [0]을 사용하여 스칼라 값으로 변환
        pred_start_val = denorm(preds_start[idx]).item() 
        
        plt.plot(actual_past, 'g--', alpha=0.4, label='Past (Input)')
        plt.plot(actual_future, 'b-', alpha=0.7, label='Actual Future')
        plt.plot(pred_curve, 'r-', linewidth=2, label='Pred Curve')
        plt.scatter(0, pred_start_val, color='black', zorder=5, s=40, label='Pred Start V')
        
        # 이제 .4f 포맷팅이 정상적으로 작동합니다.
        start_error = abs(actual_future[0] - pred_start_val)
        # 만약 에러가 계속나면 아래 줄에서 :.4f를 제거하고 테스트해보세요.
        plt.title(f"Sample {idx}\nGap: {X_g[idx][0]:.2f} | Start Err: {float(start_error):.4f}V")
        
        if i == 0: plt.legend(loc='lower left', fontsize='small')
        plt.ylim(2.4, 4.3)
        plt.grid(True, alpha=0.2)

    plt.tight_layout()
    plt.show()


# 실행
plot_resnet_hybrid_results(generator, X_p_te, X_g_te, y_f_te, v_min, v_max, num_samples=10)
