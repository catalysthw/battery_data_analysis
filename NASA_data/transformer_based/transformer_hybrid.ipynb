import random
import matplotlib.pyplot as plt
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score, mean_absolute_error
import tensorflow as tf
from tensorflow.keras import layers, Model
from scipy.interpolate import interp1d


# [Step 1] Transformer 핵심 블록 정의
def transformer_encoder(inputs, head_size, num_heads, ff_dim, dropout=0):
    
    # 1. Self-Attention
    x = layers.LayerNormalization(epsilon=1e-6)(inputs)
    x = layers.MultiHeadAttention(
        key_dim=head_size, num_heads=num_heads, dropout=dropout
    )(x, x)
    x = layers.Dropout(dropout)(x)
    res = x + inputs # Skip Connection

    # 2. Feed Forward Network
    x = layers.LayerNormalization(epsilon=1e-6)(res)
    x = layers.Conv1D(filters=ff_dim, kernel_size=1, activation="relu")(x)
    x = layers.Dropout(dropout)(x)
    x = layers.Conv1D(filters=inputs.shape[-1], kernel_size=1)(x)
    return x + res # Skip Connection

# [Step 2] Transformer 하이브리드 모델 빌드
def build_transformer_hybrid_model(seq_shape, stats_shape):
    # A. 시계열 입력 (방전 곡선 150 step)
    seq_in = layers.Input(shape=seq_shape, name='seq_input')
    
    # Positional Encoding 대용 (1D Conv로 지역적 순서 정보 강화)
    x = layers.Conv1D(64, kernel_size=3, padding='same', activation='relu')(seq_in)
    
    # Transformer Blocks (2단 적층)
    x = transformer_encoder(x, head_size=64, num_heads=4, ff_dim=64, dropout=0.1)
    x = transformer_encoder(x, head_size=64, num_heads=4, ff_dim=64, dropout=0.1)
    
    # Global Pooling (시퀀스 전체의 특징을 하나로 압축)
    x = layers.GlobalAveragePooling1D()(x)
    
    # B. 물리 피처 입력 (v_jump, total_cap, cycle_count 등)
    stats_in = layers.Input(shape=stats_shape, name='stats_input')
    y = layers.Dense(32, activation='swish')(stats_in)
    y = layers.Dense(16, activation='swish')(y)
    
    # C. 하이브리드 결합
    merged = layers.concatenate([x, y])
    z = layers.Dense(64, activation='swish')(merged)
    z = layers.Dropout(0.2)(z)
    
    # 최종 출력
    output = layers.Dense(1, activation='linear')(z)
    
    model = Model(inputs=[seq_in, stats_in], outputs=output)
    model.compile(
        optimizer=tf.keras.optimizers.Adam(learning_rate=1e-4),
        loss=tf.keras.losses.Huber(), # 이상치에 강한 손실 함수
        metrics=['mae']
    )
    return model



# [Step 3] 데이터 준비 및 ID 기반 분할
# 1. 피처 추출 및 정규화 (0~1)
def prepare_ultimate_dataset(metadata, data_folder, target_steps=150):
    all_X_seq, all_X_stats, all_y, all_ids, all_max_cycles = [], [], [], [], []
    discharge_meta = metadata[metadata['type'] == 'discharge'].copy()
    unique_battery_ids = discharge_meta['battery_id'].unique()

    # 함수 실행 전 테스트
    test_path = os.path.join(data_folder, "data")
    print(f"데이터 폴더 존재 여부: {os.path.exists(test_path)}")
    print(f"첫 번째 파일 예시: {os.listdir(test_path)[0] if os.path.exists(test_path) else '폴더 없음'}")
            
    
    for b_id in unique_battery_ids:
        b_df = discharge_meta[discharge_meta['battery_id'] == b_id].sort_values('filename')
        max_cycle_count = len(b_df)
        
        for i, row in enumerate(b_df.itertuples(), 1):
            file_path = os.path.join(data_folder, "data", row.filename)
            
            if not os.path.exists(file_path): continue
                
            try:
                df = pd.read_csv(file_path)
                if len(df) < 10: continue

                # [A] CNN용 Raw 시퀀스 (보간법)
                cols = ['Time', 'Voltage_measured', 'Voltage_load', 'Current_measured', 'Temperature_measured']
                raw_values = df[cols].values
                interp_func = interp1d(np.linspace(0, 1, len(df)), raw_values, axis=0, kind='linear')
                resampled_seq = interp_func(np.linspace(0, 1, target_steps))

                # [B] DNN용 물리 특징 (웬디님 피처 로직)
                v_init = df['Voltage_measured'].iloc[0]
                try:
                    v_drop_idx = df[df['Current_measured'].abs() > 0.1].index[0]
                    v_jump = v_init - df['Voltage_measured'].iloc[v_drop_idx]
                except: v_jump = 0
                
                dt = df['Time'].diff().fillna(0)
                total_cap = (df['Current_measured'].abs() * dt).sum() / 3600
                temp_delta = df['Temperature_measured'].max() - df['Temperature_measured'].min()

                # DNN 입력: [현재 사이클 비율, v_jump, total_cap, temp_delta]
                # i/max_cycle_count를 넣어 모델에게 '진행률' 맥락을 줍니다.
                stat_vector = [i / max_cycle_count, v_jump, total_cap, temp_delta]

                all_X_seq.append(resampled_seq)
                all_X_stats.append(stat_vector)
                
                # [핵심] 정답(y)을 0~1 사이의 잔여 수명 비율로 설정
                all_y.append((max_cycle_count - i) / max_cycle_count)
                all_ids.append(b_id)
                all_max_cycles.append(max_cycle_count) # 나중에 결과 복원용
                
            except: continue
                
    return np.array(all_X_seq), np.array(all_X_stats), np.array(all_y), np.array(all_ids), np.array(all_max_cycles)


